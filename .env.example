# QRotation - Environment Configuration
# Development Settings

# Flask Settings
FLASK_ENV=development
SECRET_KEY=
DEBUG=True
# Leave enabled for an empty development database; set false for managed production data.
SEED_INITIAL_DATA=true

# Database
DATABASE_URL=

# JWT
JWT_SECRET=

# QR Code Settings (FIXED: Increased timeout to prevent expiration)

QR_EXPIRY_SECONDS=90
QR_ROTATION_INTERVAL=30
QR_GRACE_PERIOD_SECONDS=30

# Server
HOST=0.0.0.0
PORT=5000



# Geolocation
ENABLE_GEOLOCATION=true
REQUIRE_GEOLOCATION=false
LOCATION_VERIFICATION_RADIUS=100

# IANA timezone used to interpret scheduled class times.
CAMPUS_TIMEZONE=Asia/Kolkata

# Optional anti-fraud and classroom-presence settings
MAX_REGISTERED_DEVICES=2
FRAUD_SCAN_WINDOW_SECONDS=8
FRAUD_SHARED_QR_MIN_SCANS=8
CLASSROOM_BEACONS={}

# Classroom Locations (Latitude, Longitude)
# Default: Mumbai coordinates - Replace with your actual classroom coordinates
# Get coordinates from Google Maps: Right-click location -> "What's here?"
CLASSROOM_LAT=
CLASSROOM_LNG=
CLASSROOM_RADIUS=100

# Session Security
SESSION_COOKIE_SECURE=false
REMEMBER_COOKIE_SECURE=false
